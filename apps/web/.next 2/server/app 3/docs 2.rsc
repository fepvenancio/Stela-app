17:["$","section",null,{"children":[["$","h2",null,{"className":"font-display text-3xl sm:text-4xl text-chalk tracking-tight mb-8","children":"Knowledge Base"}],["$","div",null,{"className":"grid sm:grid-cols-2 gap-6","children":[["$","div","What happens if no one lends to my inscription?",{"className":"bg-abyss border border-edge/20 rounded-lg p-8 hover:border-star/20 transition-colors","children":[["$","h4",null,{"className":"font-display text-chalk text-sm tracking-widest uppercase mb-4","children":"What happens if no one lends to my inscription?"}],["$","p",null,{"className":"text-dust text-sm leading-relaxed","children":"The inscription will eventually hit its deadline and expire. No debt was ever provided, so your collateral remains safe. You can reclaim it by cancelling the expired Stela."}]]}],["$","div","Can I cancel after a lender has signed?",{"className":"bg-abyss border border-edge/20 rounded-lg p-8 hover:border-star/20 transition-colors","children":[["$","h4",null,{"className":"font-display text-chalk text-sm tracking-widest uppercase mb-4","children":"Can I cancel after a lender has signed?"}],["$","p",null,{"className":"text-dust text-sm leading-relaxed","children":"No. Signature creates an immutable on-chain debt obligation. You must repay the debt plus pro-rated interest within the duration to release your collateral."}]]}],["$","div","Is there an oracle or price feed?",{"className":"bg-abyss border border-edge/20 rounded-lg p-8 hover:border-star/20 transition-colors","children":[["$","h4",null,{"className":"font-display text-chalk text-sm tracking-widest uppercase mb-4","children":"Is there an oracle or price feed?"}],["$","p",null,{"className":"text-dust text-sm leading-relaxed","children":"No. Stela is oracle-free. It does not liquidate based on price fluctuations, only on time. This eliminates oracle manipulation risks."}]]}],["$","div","Can I create multiple orders at once?",{"className":"bg-abyss border border-edge/20 rounded-lg p-8 hover:border-star/20 transition-colors","children":[["$","h4",null,{"className":"font-display text-chalk text-sm tracking-widest uppercase mb-4","children":"Can I create multiple orders at once?"}],["$","p",null,{"className":"text-dust text-sm leading-relaxed","children":"Yes. You can post several orders with different terms simultaneously — like limit orders on an exchange. Lenders choose which to fund. When one settles, all others from the same nonce are automatically cancelled. Only one can ever fill."}]]}],["$","div","Are shares transferable?",{"className":"bg-abyss border border-edge/20 rounded-lg p-8 hover:border-star/20 transition-colors","children":[["$","h4",null,{"className":"font-display text-chalk text-sm tracking-widest uppercase mb-4","children":"Are shares transferable?"}],["$","p",null,{"className":"text-dust text-sm leading-relaxed","children":"Yes. Every lending position is an ERC1155 token. You can transfer your shares to another address, and they will hold the right to claim the assets."}]]}],["$","div","Do I pay full interest if I repay early?",{"className":"bg-abyss border border-edge/20 rounded-lg p-8 hover:border-star/20 transition-colors","children":[["$","h4",null,{"className":"font-display text-chalk text-sm tracking-widest uppercase mb-4","children":"Do I pay full interest if I repay early?"}],["$","p",null,{"className":"text-dust text-sm leading-relaxed","children":"No. Interest is pro-rated by elapsed time using ceil(interest x elapsed / duration). Repaying a 30-day loan at day 15 costs roughly half the interest. Rounding is ceiling (up) so lenders always receive at least 1 wei. Swaps (duration = 0) always charge full interest."}]]}]]}]]}]
18:["$","section",null,{"children":[["$","h2",null,{"className":"font-display text-3xl sm:text-4xl text-chalk tracking-tight mb-8","children":"Architecture"}],["$","p",null,{"className":"text-dust mb-8 leading-relaxed","children":"Stela is a fully on-chain protocol with off-chain indexing for discovery. All state transitions happen through direct smart contract interactions — the backend never proxies writes."}],["$","div",null,{"className":"grid sm:grid-cols-2 gap-4","children":[["$","div",null,{"className":"bg-abyss border border-edge/20 rounded-lg p-6 group hover:border-star/20 transition-all","children":[["$","span",null,{"className":"text-[10px] text-dust uppercase tracking-[0.2em] block mb-3 font-bold","children":"Smart Contracts (Cairo)"}],["$","div",null,{"className":"text-sm text-chalk leading-relaxed ","children":["$","p",null,{"className":"text-dust text-sm","children":"Core protocol logic, inscription state machine, locker deployment, share minting. Written in Cairo for StarkNet."}]}]]}],["$","div",null,{"className":"bg-abyss border border-edge/20 rounded-lg p-6 group hover:border-star/20 transition-all","children":[["$","span",null,{"className":"text-[10px] text-dust uppercase tracking-[0.2em] block mb-3 font-bold","children":"Indexer (Cloudflare Worker)"}],["$","div",null,{"className":"text-sm text-chalk leading-relaxed ","children":["$","p",null,{"className":"text-dust text-sm","children":"Polls StarkNet RPC for contract events and writes to D1 (SQLite). Enables browsing and discovery of inscriptions."}]}]]}],["$","div",null,{"className":"bg-abyss border border-edge/20 rounded-lg p-6 group hover:border-star/20 transition-all","children":[["$","span",null,{"className":"text-[10px] text-dust uppercase tracking-[0.2em] block mb-3 font-bold","children":"Frontend (Next.js)"}],["$","div",null,{"className":"text-sm text-chalk leading-relaxed ","children":["$","p",null,{"className":"text-dust text-sm","children":"Server-rendered UI deployed on Cloudflare. Reads from D1 for listing, connects directly to StarkNet for writes via user wallet."}]}]]}],["$","div",null,{"className":"bg-abyss border border-edge/20 rounded-lg p-6 group hover:border-star/20 transition-all","children":[["$","span",null,{"className":"text-[10px] text-dust uppercase tracking-[0.2em] block mb-3 font-bold","children":"Liquidation Bot (Cloudflare Worker)"}],["$","div",null,{"className":"text-sm text-chalk leading-relaxed ","children":["$","p",null,{"className":"text-dust text-sm","children":"Automated cron job that monitors for expired inscriptions and executes liquidations on-chain."}]}]]}]]}]]}]
